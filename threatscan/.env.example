# ============================================================
#  ThreatScan Agentic Core — Environment Configuration
#  Copy this file to .env and fill in your real values.
#  All keys are optional — the system gracefully degrades
#  to simulation mode when a key is absent or left as-is.
# ============================================================


# ────────────────────────────────────────────────────────────
#  CORE LLM (Required for real AI-powered analysis)
#  Used by: Hunter (code analysis), RedTeam (exploit synthesis),
#           Architect (patch generation), Historian (report writing)
# ────────────────────────────────────────────────────────────

# Anthropic Claude — primary analysis engine
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model to use for heavy analysis tasks (default: claude-opus-4-6)
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-opus-4-6

# Model for fast/cheap tasks (triage, summaries)
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# Max tokens for analysis responses
ANTHROPIC_MAX_TOKENS=4096


# ────────────────────────────────────────────────────────────
#  RECONNAISSANCE — Shadow Agent
# ────────────────────────────────────────────────────────────

# Shodan — internet-wide asset intelligence
# Get yours at: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# SecurityTrails — subdomain enumeration, DNS history
# Get yours at: https://securitytrails.com/app/account/credentials
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# VirusTotal — URL/domain/IP reputation
# Get yours at: https://www.virustotal.com/gui/user/apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Certificate Transparency log source (no auth needed, but configurable)
# Default: https://crt.sh
CT_LOG_URL=https://crt.sh

# HTTP probe timeout in seconds (default: 10)
HTTP_PROBE_TIMEOUT=10

# Max concurrent HTTP probes (default: 20, reduce if rate-limited)
HTTP_PROBE_CONCURRENCY=20

# User-Agent header for HTTP probing
HTTP_USER_AGENT=ThreatScan/2.0 Security Scanner


# ────────────────────────────────────────────────────────────
#  VULNERABILITY INTELLIGENCE — Hunter Agent
# ────────────────────────────────────────────────────────────

# NVD (National Vulnerability Database) API key — rate limit: 5 req/s with key vs 5/30s without
# Get yours at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# OSV (Open Source Vulnerabilities) — no key needed, but configurable
# Default: https://api.osv.dev
OSV_API_URL=https://api.osv.dev

# Snyk — dependency vulnerability scanning
# Get yours at: https://app.snyk.io/account
SNYK_API_TOKEN=your_snyk_token_here

# GitHub — for repo scanning, dependency graph, secret scanning alerts
# Create at: https://github.com/settings/tokens (needs: repo, read:org)
GITHUB_TOKEN=your_github_token_here


# ────────────────────────────────────────────────────────────
#  THREAT INTELLIGENCE — Historian Agent
# ────────────────────────────────────────────────────────────

# CISA KEV (Known Exploited Vulnerabilities) — no auth needed, public feed
# Default: https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# GreyNoise — distinguishes targeted attacks from internet noise
# Get yours at: https://www.greynoise.io/viz/account/
GREYNOISE_API_KEY=your_greynoise_api_key_here

# AlienVault OTX — open threat exchange
# Get yours at: https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here


# ────────────────────────────────────────────────────────────
#  VECTOR DATABASE — Historian Agent (long-term memory)
#  Enables cross-scan learning and semantic similarity search
# ────────────────────────────────────────────────────────────

# Qdrant — vector DB for episodic memory
# Self-hosted: docker run -p 6333:6333 qdrant/qdrant
# Cloud: https://cloud.qdrant.io/
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here_or_leave_empty_for_local
QDRANT_COLLECTION=threatscan_memory

# Embedding model for findings (used when Qdrant is available)
# Options: openai | anthropic | local (sentence-transformers)
EMBEDDING_PROVIDER=anthropic


# ────────────────────────────────────────────────────────────
#  STATIC ANALYSIS TOOLS — Hunter Agent
# ────────────────────────────────────────────────────────────

# Semgrep — static analysis rules engine
# Install: pip install semgrep | brew install semgrep
# App token (optional, for cloud rules): https://semgrep.dev/orgs/-/settings/tokens
SEMGREP_APP_TOKEN=your_semgrep_token_here

# Path to semgrep binary (default: auto-detect from PATH)
SEMGREP_BIN=semgrep

# Path to bandit binary for Python scanning (default: auto-detect)
BANDIT_BIN=bandit


# ────────────────────────────────────────────────────────────
#  SCAN BEHAVIOUR
# ────────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log to file (leave empty to log to stdout only)
LOG_FILE=

# Max parallel agent tasks (default: 10)
MAX_PARALLEL_TASKS=10

# Enable real HTTP probing (true) or full simulation (false)
# WARNING: Only enable against targets you own or have permission to scan
ENABLE_REAL_HTTP_PROBING=false

# Enable real LLM calls (true) or use heuristic fallbacks (false)
# Set to false to run the entire pipeline without spending API credits
ENABLE_LLM_ANALYSIS=true

# Enable real threat intel API calls (true) or use cached/simulated data (false)
ENABLE_THREAT_INTEL=true

# Enable vector DB memory (true) or in-memory only (false)
ENABLE_VECTOR_MEMORY=false

# Enable Semgrep/Bandit static analysis (true) or internal taint engine only (false)
ENABLE_STATIC_TOOLS=false

# Scan timeout in seconds (default: 300 = 5 minutes)
SCAN_TIMEOUT=300

# Output directory for reports and scan artifacts
OUTPUT_DIR=./scan_output

# Report formats to generate (comma-separated): json,sarif,html,pdf
REPORT_FORMATS=json,html
